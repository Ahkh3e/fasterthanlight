# Copy to .env and replace placeholders

# Public hostname for backend API via Cloudflare Tunnel
# Example: https://ftl-api.yourdomain.com
VITE_API_URL=https://ftl-api.yourdomain.com

# Public hostname for backend websocket via Cloudflare Tunnel
# Same host as API, but wss scheme
# Example: wss://ftl-api.yourdomain.com
VITE_WS_URL=wss://ftl-api.yourdomain.com

# Cloudflare Tunnel token from Zero Trust dashboard
CF_TUNNEL_TOKEN=replace_with_your_tunnel_token
